#!/bin/sh

set -e

BEOUTOS_VERSION="1.0.0"
BEOUTOS_CODENAME="atlas"
DEBIAN_MIRROR="http://deb.debian.org/debian"
SECURITY_MIRROR="http://security.debian.org/debian-security"

lb config noauto \
    --architecture amd64 \
    --distribution bookworm \
    --parent-distribution bookworm \
    --archive-areas main \
    --parent-archive-areas main \
    --apt-recommends false \
    --apt-secure true \
    --mirror-bootstrap "${DEBIAN_MIRROR}" \
    --mirror-chroot "${DEBIAN_MIRROR}" \
    --mirror-chroot-security "${SECURITY_MIRROR}" \
    --mirror-binary "${DEBIAN_MIRROR}" \
    --mirror-binary-security "${SECURITY_MIRROR}" \
    --bootstrap debootstrap \
    --bootstrap-flavour minimal \
    --image-type iso-hybrid \
    --binary-images iso-hybrid \
    --iso-application "BeoutOS" \
    --iso-publisher "Beout Security; https://beout.ai" \
    --iso-volume BeoutOS_${BEOUTOS_VERSION_${BEOUTOS_CODENAME}" \
    --bootloaders grub-efi \
    --uefi-secure-boot enable \
    --firmware-chroot true \
    --firmware-binary true \
    --linux-flavour amd64 \
    --linux-packages "linux-image-amd64" \
    --squashfs-compression-type xz \
    --squashfs-compression-level 9 \
    --chroot-filesystem squashfs \
    --hostname horus \
    --username beoutos-admin \
    --root-filesystem-size 4096 \
    --iso-preparer "live-build ${BEOUTOS_VERSION}" \
    --syslinux-menu false \
    --grub-splash "" \
    --apt-options "--yes -o Acquire::Retries=3 -o Acquire::http::Timeout=60" \
    --dpkg-options "--force-unsafe-iter" \
    --debconf-frontend noninteractive \
    --initramfs live-boot \
    --initramfs-compression xz \
    --ram-options "size=50%" \
    --mode debian \
    --system live \
    --zsync false \
    --backports false \
    --updates true \
    ${@}

cat > config/archives/security.list.chroot <<EOF
deb ${SECURITY_MIRROR} bookworm-security main
EOF

cat > config/archives/security.list.binary <<EOF
deb ${SECURITY_MIRROR} bookworm-security main
EOF

cat > config/archives/debian.list.chroot <<EOF
deb ${DEBIAN_MIRROR} bookworm main
deb ${DEBIAN_MIRROR} bookworm-updates main
EOF

cat > config/archives/debian.list.binary <<EOF
deb ${DEBIAN_MIRROR} bookworm main
deb ${DEBIAN_MIRROR} bookworm-updates main
EOF
