#!/bin/bash

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BUILD_DIR="$(dirname "${SCRIPT_DIR}")"

cd "${BUILD_DIR}"

ALL_CLEAN=false
if [ "${1}" = "--all" ] || [ "${1}" = "-a" ]; then
    ALL_CLEAN=true
fi

if [ "${ALL_CLEAN}" = true ]; then
    echo "Performing complete clean of all build artifacts and caches..."

    lb clean --all 2>&1 || true

    rm -rf cache
    rm -rf config/.stage
    rm -rf chroot
    rm -rf binary
    rm -rf source
    rm -rf *.iso
    rm -rf *.img
    rm -rf build-logs
    rm -rf local
    rm -rf config/archives
    rm -rf config/bootstrap
    rm -rf config/chroot
    rm -rf config/binary
    rm -rf config/common
    rm -rf config/source

    echo "Complete clean finished."
else
    echo "Performing standard clean of build artifacts..."

    lb clean 2>&1 || true

    rm -rf binary
    rm -rf chroot
    rm -rf *.iso
    rm -rf *.img

    echo "Standard clean finished. Caches and config preserved for resume builds."
fi

exit 0
